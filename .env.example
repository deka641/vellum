DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vellum"
AUTH_SECRET="your-secret-key-here"
# Optional: Override base URL for canonical links, sitemaps, and OG tags (auto-detected from request headers if unset)
# NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Optional: SMTP configuration for email notifications (form submissions)
# If SMTP_HOST is not set, notifications are logged to the console instead of emailed.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"                    # 587 for STARTTLS, 465 for SSL
# SMTP_USER="your-smtp-username"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="noreply@yourdomain.com" # Defaults to SMTP_USER if not set
